{
  "type": "object",
  "required": [
    "name",
    "description",
    "finalGoal",
    "dailyTasks",
    "finalChallenges"
  ],
  "properties": {
    "name": {
      "type": "string",
      "maxLength": 75
    },
    "description": {
      "type": "string",
      "maxLength": 250
    },
    "finalGoal": {
      "type": "string"
    },

    "dailyTasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["day", "tasks", "motivation"],
        "properties": {
          "day": {
            "type": "number",
            "minimum": 1
          },

          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["title", "description"],
              "properties": {
                "title": {
                  "type": "string"
                },
                "description": {
                  "type": "string",
                  "maxLength": 325
                }
              },
              "additionalProperties": false
            }
          },

          "motivation": {
            "type": "string",
            "maxLength": 150
          }
        },
        "additionalProperties": false
      }
    },

    "finalChallenges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "description"],
        "properties": {
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string",
            "maxLength": 325
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
